# gdrive-serve-lite endpoint. Include its --baseurl path when one is configured.
GDRIVE_BASE_URL=http://127.0.0.1:8765/gdrive

# Optional: set when gdrive-serve-lite is started with --user and --pass.
# GDRIVE_USER=gdrive-user
# GDRIVE_PASS=gdrive-password

# Optional timeouts for large Drive roots or slow upstream responses.
# GDRIVE_LIST_TIMEOUT_MS=120000
# GDRIVE_METADATA_TIMEOUT_MS=30000
# GDRIVE_READ_TIMEOUT_MS=300000

# Page-first browsing controls.
# EVENT_PAGE_SIZE=48
# EVENT_PAGE_SCAN_CONCURRENCY=8
# GDRIVE_EVENT_ORDER_BY=name desc

# Server port (optional, default: 3001)
# PORT=3001
